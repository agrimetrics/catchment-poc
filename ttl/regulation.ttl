<http://example.com/water-regulation/substance/0135> a skos:Concept,
        sosa:ObservableProperty ;
    skos:inScheme <http://example.com/water-regulation/substance> ;
    skos:notation "0135" ;
    skos:prefLabel "Solids, Suspended at 105 C" .

<http://example.com/water-regulation/unit/ph-units> a ns1:Unit ;
    skos:prefLabel "PH UNITS" .

<http://example.com/water-regulation/statistical-modifier/maximum> a ns4:StatisticalModifier,
        skos:Concept ;
    dcterms:source <https://www.gov.uk/government/publications/site-specific-quality-numeric-permit-limits-discharges-to-surface-water-and-groundwater/site-specific-quality-numeric-permit-limits-discharges-to-surface-water-and-groundwater> ;
    skos:definition "A concentration that no sample result must exceed. Assessed per sample: if a result exceeds it, that is a failure. Where a permit also carries a 95th-percentile limit for the same substance, this maximum is the upper-tier backstop and the percentile is the binding limit." ;
    skos:inScheme <http://example.com/water-regulation/statistical-modifier> ;
    skos:prefLabel "Maximum (absolute)" .

<http://example.com/water-regulation/statistical-modifier/percentile-95> a ns4:StatisticalModifier,
        skos:Concept ;
    dcterms:source <https://www.gov.uk/government/publications/site-specific-quality-numeric-permit-limits-discharges-to-surface-water-and-groundwater/site-specific-quality-numeric-permit-limits-discharges-to-surface-water-and-groundwater> ;
    skos:altLabel "95 percentile" ;
    skos:definition "A concentration the discharge must be under at least 95% of the time. NOT a per-sample rule: assessed over a 12-month period, where each sample above the value is a look-up-table (LUT) exceedance and the permit fails only if the count of exceedances is greater than the maximum allowed for that number of samples." ;
    skos:inScheme <http://example.com/water-regulation/statistical-modifier> ;
    skos:prefLabel "95th percentile" .

<http://example.com/water-regulation/unit/milligram-per-litre> a ns1:Unit ;
    owl:sameAs <http://qudt.org/vocab/unit/MilliGM-PER-L> ;
    skos:prefLabel "MILLIGRAM PER LITRE" .

