<http://example.com/water-regulation/breach/ff470bd09d03c849bdfc381e226aa828> a ns2:ExceedanceBreach,
        ns2:LimitBreach ;
    ns3:hasApplicability <http://example.com/water-regulation/breach/ff470bd09d03c849bdfc381e226aa828#applicability> ;
    ns2:breachesCondition <http://example.com/water-regulation/permit/043241/version/1/outlet/1/effluent/1/condition/0135> ;
    ns2:breachesLimit <http://example.com/water-regulation/permit/043241/version/1/outlet/1/effluent/1/condition/0135#limit-maximum> ;
    ns2:evidencedByObservation <http://environment.data.gov.uk/water-quality/sampling-point/SW-50580170/sample/2599875/observation/0135> ;
    ns1:judgedOnUndatedVersion true ;
    rdfs:comment "38.3 above the 20 maximum" .

ns1:judgedOnUndatedVersion rdfs:label "judged on an undated permit version" ;
    rdfs:comment "The judgement rests on a permit version the register does not date. The permit has exactly ONE version, so WHICH limits applied is not in doubt - only the period the permit ran between. It is a weaker claim than a breach of a dated version, and is flagged so that it can be told apart from one. The explanation lives HERE, on the property, and not as a second rdfs:comment on every breach - which is what it was, and which quietly doubled every affected breach in any query that read rdfs:comment through an OPTIONAL." .

