<http://example.com/water-regulation/assessment-obstacle/too-few-samples> a skos:Concept ;
    skos:definition "Assessed, but every 12-month window held fewer samples than the method needs (n < 4 for the 95th-percentile look-up table, n < 2 for a mean)." ;
    skos:inScheme ns1:assessment-obstacle ;
    skos:notation "too-few-samples" .

<http://example.com/water-regulation/permit/043241/version/1/outlet/1/effluent/1/condition/0135> ns1:assessed true .

<http://example.com/water-regulation/assessment-obstacle/no-observations-in-a-dated-window> a skos:Concept ;
    skos:definition "Compliance samples exist for this determinand at this point, but none of them falls inside a dated window of this permit version." ;
    skos:inScheme ns1:assessment-obstacle ;
    skos:notation "no-observations-in-a-dated-window" .

<http://example.com/water-regulation/assessment-obstacle/sampling-point-unpublished> a skos:Concept ;
    skos:definition "The register names a sampling point, but the Water Quality Archive publishes no data for it. The point exists; its observations are not open." ;
    skos:inScheme ns1:assessment-obstacle ;
    skos:notation "sampling-point-unpublished" .

<http://example.com/water-regulation/assessment-obstacle/ambiguous-version-history> a skos:Concept ;
    skos:definition "The register dates none of this permit's versions AND the versions DISAGREE about this particular limit, so which value applied on the day a sample was taken cannot be known. Note how narrow this is: it is a fact about the LIMIT, not the permit. Where every version states the SAME bound - which is the overwhelming majority, even on permits with several versions - there is nothing to choose between, the condition IS assessed, and the judgement is flagged as resting on an undated version. A permit can have some conditions assessed and others not." ;
    skos:inScheme ns1:assessment-obstacle ;
    skos:notation "ambiguous-version-history" .

<http://example.com/water-regulation/permit/051340/version/1/outlet/2/effluent/1/condition/0135> ns1:assessed true .

<http://example.com/water-regulation/assessment-obstacle/no-sampling-point> a skos:Concept ;
    skos:definition "The permit register names no sampling point for this effluent. Nothing monitors it, so nothing can evidence a breach of it." ;
    skos:inScheme ns1:assessment-obstacle ;
    skos:notation "no-sampling-point" .

<http://example.com/water-regulation/assessment-obstacle/no-observations> a skos:Concept ;
    skos:definition "The sampling point and the determinand are both known and the archive holds no compliance sample for the pair. Common for the flow, weir-setting and storm-overflow telemetry conditions the register sets but the archive does not carry here." ;
    skos:inScheme ns1:assessment-obstacle ;
    skos:notation "no-observations" .

