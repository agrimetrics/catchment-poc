<http://example.com/sfi/Option/Concept/WBD5#payment-rate> a ns2:PaymentRate ;
    rdfs:label "per hectare" ;
    ns2:perQuantity <http://example.com/sfi/Option/Concept/WBD5#payment-per> ;
