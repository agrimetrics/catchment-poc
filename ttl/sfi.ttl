<http://example.com/sfi/Option/Concept/IPM3> a skos:Concept ;
    skos:broader <http://example.com/sfi/Option/Concept/IPM> ;
    skos:definition "Companion crop on arable and horticultural land" ;
    skos:inScheme <http://example.com/sfi/Option> ;
