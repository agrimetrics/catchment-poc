# Catchment source SPARQL endpoint — TEMPLATE ONLY.
#
# Copy to .env and fill in. .env is gitignored; this example file is not, and must
# never contain real values.
#
#   cp .env.example .env && chmod 600 .env && $EDITOR .env
#
# Load into a shell without echoing:  set -a; . ./.env; set +a
# The extraction scripts read these via os.environ — see ttl/catchment/README.md.

CDE_SPARQL_ENDPOINT=
CDE_SPARQL_USER=
CDE_SPARQL_PASSWORD=
CDE_REPOSITORY=
