/.venv
/venv

# Regenerable SFI artifacts - the database is rebuilt from raw_datasets by
# ttl/sfi/sfi_to_db.py and sfi_raw.ttl is the ontop materialisation intermediate
# (piped through rdfpipe into ttl/sfi.ttl), so neither needs to be committed.
ttl/sfi/sfi.duckdb
ttl/sfi/sfi_raw.ttl

# Regenerable regulation artifacts - the database is shredded from the observations
# CSV by ttl/regulation/regulation_to_db.py and regulation_raw.ttl is the ontop
# materialisation intermediate (piped through rdfpipe into ttl/regulation.ttl).
ttl/regulation/regulation.duckdb
ttl/regulation/regulation_raw.ttl

# Regenerable WINEP artifacts - the database is shredded from the PR24 WINEP xlsx by
# ttl/winep/winep_to_db.py and winep_raw.ttl is the ontop materialisation intermediate
# (piped through rdfpipe into ttl/winep.ttl).
ttl/winep/winep.duckdb
ttl/winep/winep_raw.ttl

# output_data/ is 100% generated by link_data.py — the regulation shredder's input
# (observations_with_permits_and_rules.csv) plus unused byproducts. No source inputs live here;
# determinand_codelist.json now lives in raw_datasets/.
/output_data/

# Excel
\~*.xlsx

# Outing the MacOS users
.DS_Store

# Firefox/Marionette screenshot driver artifact
gecko.log
