/.venv
/venv

# Regenerable SFI artifacts - the database is rebuilt from raw_datasets by
# ttl/sfi/sfi_to_db.py and sfi_raw.ttl is the ontop materialisation intermediate
# (piped through rdfpipe into ttl/sfi.ttl), so neither needs to be committed.
ttl/sfi/sfi.duckdb
ttl/sfi/sfi_raw.ttl

# Regenerable regulation artifacts - the database is shredded from the observations
# CSV by ttl/regulation/regulation_to_db.py and regulation_raw.ttl is the ontop
# materialisation intermediate (piped through rdfpipe into ttl/regulation.ttl).
ttl/regulation/regulation.duckdb
ttl/regulation/regulation_raw.ttl

# Regenerable WINEP artifacts - the database is shredded from the PR24 WINEP xlsx by
# ttl/winep/winep_to_db.py and winep_raw.ttl is the ontop materialisation intermediate
# (piped through rdfpipe into ttl/winep.ttl).
ttl/winep/winep.duckdb
ttl/winep/winep_raw.ttl

# output_data/ is 100% generated by link_data.py — the regulation shredder's input
# (observations_with_permits_and_rules.csv) plus unused byproducts. No source inputs live here;
# determinand_codelist.json now lives in raw_datasets/.
/output_data/

# Excel
\~*.xlsx

# Outing the MacOS users
.DS_Store

# Credentials for the catchment source endpoint (and anything else). NOTHING matching these
# patterns is ever committed. Listed BEFORE any such file exists, deliberately: a secret that
# reaches a commit is compromised even if the next commit removes it, because it stays in the
# object history and in every clone. The guard has to predate the file.
.env
.env.*
!.env.example
*.netrc
.netrc
secrets.json
*.credentials

# Firefox/Marionette screenshot driver artifact
gecko.log

# Python bytecode
__pycache__/
*.pyc

# Safety net: app/server.py's disk caches (observations + basemap tiles) default to a temp dir OUTSIDE
# the repo, so downloaded data never lands here. These patterns only matter if CACHE_DIR is pointed
# back into the tree — they keep that from ever being committed.
/.obs_cache/
/.tile_cache/

# Regenerable: breaches.duckdb is rebuilt from compliance_observations.csv by
# ttl/breaches/breaches_to_db.py and breaches_raw.ttl is the ontop materialisation
# intermediate (canonicalised into ttl/breaches.ttl by rdfpipe).
# compliance_observations.csv IS committed - it is a fetched input, not a rebuild artefact,
# so the breach build runs offline.
ttl/breaches/breaches.duckdb
ttl/breaches/breaches_raw.ttl

# NOTHING is ignored for ttl/catchment, deliberately. catchment_raw.ttl is the CONSTRUCT output
# from the source SPARQL endpoint, canonicalised into ttl/catchment.ttl by rdfpipe. Every other
# dataset ignores its *_raw.ttl because it can be rebuilt from a committed local input — this one
# cannot: the source is not publicly reachable. So the raw extract IS committed, exactly as
# compliance_observations.csv is for breaches, and for the same reason: the build must run offline.
